# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore

# Metro
.metro-health-check*

# Debug / logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS / Windows
.DS_Store
Thumbs.db
*.pem

# Environment (do not commit secrets)
.env
.env.*
!.env.example

# TypeScript
*.tsbuildinfo

# Tests / coverage
coverage/

# Temp
tmp/
temp/

# Legacy / examples
app-example

# Generated native folders (regenerate with `npx expo prebuild` if needed)
/ios
/android

# PHP (Composer — not used in this repo yet; ignore if added later)
vendor/

# Runtime user uploads (profile images); directory tracked via .gitkeep only
workconnect-api/uploads/*
!workconnect-api/uploads/.gitkeep
